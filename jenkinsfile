pipeline {
agent any
stages { 
 
        stage('Clone Code') { 
            steps { 
                git branch: 'main', url: https://github.com/aarthiganesan2805-web/jenkinsfile.git 
            } 
        } 
 
        stage('Compile Code') { 
            steps { 
                bat 'javac demo.java' 
            } 
        } 
 
        stage('Run Code') { 
            steps { 
                bat 'java demo'
}
}
}
}
